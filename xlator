#!/bin/bash
set -e

# Resolve SCRIPT_DIR, following symlinks if necessary
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname -- "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname -- "$SOURCE")" >/dev/null 2>&1 && pwd)"

# Resolve the user's project root (where xlator.conf lives)
if git rev-parse --show-toplevel >/dev/null 2>&1; then
    PROJECT_ROOT="$(git rev-parse --show-toplevel)"
elif [ -f "$PWD/xlator.conf" ]; then
    PROJECT_ROOT="$PWD"
else
    echo "Error: Cannot find project root. Run /xl:setup to create xlator.conf." >&2
    exit 1
fi

if [ "$1" = "project_root" ]; then
    echo "$PROJECT_ROOT"
    exit 0
fi


export PROJECT_ROOT
# Load per-project config (DOMAINS_DIR)
if [ ! -f "$PROJECT_ROOT/xlator.conf" ]; then
    echo "Error: xlator.conf not found at $PROJECT_ROOT/xlator.conf" >&2
    echo "Run /xl:setup in Claude Code to configure this project." >&2
    exit 1
fi

# Turn on automatic exporting of variables loaded from xlator.conf
set -o allexport
source "$PROJECT_ROOT/xlator.conf"
set +o allexport

# Activate mise if available, setting up uv and opam in PATH
activate_mise() {
    if command -v mise >/dev/null; then
        eval "$(mise activate bash)"
    elif [ -f "$HOME/.local/bin/mise" ]; then
        eval "$("$HOME/.local/bin/mise" activate bash)"
    elif [ -f "$HOME/.asdf/asdf.sh" ]; then
        # Fallback to asdf for legacy setups
        . "$HOME/.asdf/asdf.sh"
    fi
}

# Activate opam environment if initialized
activate_opam() {
    if [ -d "$HOME/.opam" ]; then
        eval "$(opam env)"
    fi
}

# Activate the per-project venv created by /xl:setup
activate_venv() {
    if [ -f "$DOMAINS_DIR/.venv/bin/activate" ]; then
        . "$DOMAINS_DIR/.venv/bin/activate"
    fi
}

cmd_setup() {
    if ! command -v mise >/dev/null && [ ! -f "$HOME/.local/bin/mise" ]; then
        echo "🤖 Installing mise..."
        curl -LsSf https://astral.sh/mise/install.sh | sh
        export PATH="$HOME/.local/bin:$PATH"
    fi
    mise trust -q
    activate_mise

    echo "🙂 1. Installing uv, rust, and opam (if missing)..."
    mise install
}

cmd_setup_in_codespace() {
    echo "Running setup in Codespace environment..."

    echo "🙂 1. Installing ninja-build and bubblewrap (if missing) for 'opam init'..."
    if ! command -v bwrap >/dev/null; then
        sudo apt update || echo "🙈 Ignoring any APT errors"

        # ninja-build is needed for 'opam init' to compile ocaml
        # bubblewrap is needed for sandboxing the OCaml compiler, which is used by 'opam init'
        sudo apt install -y ninja-build bubblewrap
    fi
}

cmd_setup_final() {
    date
    echo "😀 2. Installing Python dependencies..."
    # 'uv sync' installs the version specified in .python-version in a venv
    uv sync
    activate_venv

    date
    echo "😅 3. Initializing opam (if needed; this can take 10 minutes)..."
    if [ ! -d "$HOME/.opam" ]; then
        # Catala supports OCaml versions from 4.14.0 up to 5.4.X.
        opam init -y -a -c 5.4.1
    fi
    activate_opam

    date
    echo "😄 4. Installing Catala/clerk (if missing; this can take 10 minutes)..."
    if ! command -v clerk >/dev/null; then
        opam update && opam install -y catala.1.1.0
    fi

    date
    echo "🤩 Setup complete"
}

if [ "$1" = "setup" ]; then
    mkdir -p "$PROJECT_ROOT/$DOMAINS_DIR"
    cd "$PROJECT_ROOT/$DOMAINS_DIR"
    for F in .gitignore CLAUDE.md mise.toml pyproject.toml .python-version uv.lock; do
        if [ -f "$F" ]; then
            echo "Already exists; not overriding: $DOMAINS_DIR/$F"
        else
            cp -v "$SCRIPT_DIR/$F" .
        fi
    done

    # Create/Update $PROJECT_ROOT/CLAUDE.md
    READ_XLATOR_CLAUDE_MD="## Xlator Claude Code Plugin

Read $DOMAINS_DIR/CLAUDE.md when an \`xl\` (xlator) Claude Code plugin command runs."
    if [ ! -f "$PROJECT_ROOT/CLAUDE.md" ] || ! grep -q "Xlator Claude Code Plugin" "$PROJECT_ROOT/CLAUDE.md"; then
        echo "Appending Xlator plugin note to $PROJECT_ROOT/CLAUDE.md"
        echo -e "\n$READ_XLATOR_CLAUDE_MD" >> "$PROJECT_ROOT/CLAUDE.md"
    fi

    echo "Creating symlink to xlator at $DOMAINS_DIR/xlator"
    ln -snf "$SCRIPT_DIR/xlator" .

    # 'uv sync' installs the version specified in .python-version in a venv
    uv sync

    if [ "$CODESPACES" = "true" ]; then
        cmd_setup_in_codespace
    else
        cmd_setup
    fi
    cmd_setup_final
    exit 0
fi

# Start a new shell with mise, Python, and opam environments activated.
# Useful for running python, catala, and clerk commands directly in the terminal.
if [ "$1" = "" ]; then
    activate_mise
    activate_venv
    case "$SHELL" in
        */zsh)
            zsh --login -i -c 'source ~/.zshrc; source "$DOMAINS_DIR/.venv/bin/activate"; eval "$(opam env)"; exec zsh'
            ;;
        *)
            bash --rcfile <(
                cat ~/.bashrc 2>/dev/null || true
                echo ". \"$DOMAINS_DIR/.venv/bin/activate\""
                echo 'eval "$(opam env)"'
            )
            ;;
    esac
    exit 0
fi

# Activate tools and environments for Python and Catala/clerk.
# This is needed because Claude Code does not run shell configuration files.
activate_mise
activate_venv
activate_opam

case "$1" in
    generate-schema)
        exec python3 "$SCRIPT_DIR/tools/civil_schema.py"
        ;;
    observe_hook)
        echo "Running observe_hook with args: ${*:2}"
        exec python3 "$SCRIPT_DIR/tools/observe_hook.py" "${@:2}"
        ;;
    *)
        # Change to the $DOMAINS_DIR so that relative paths are created
        # within that folder and not the root of the repository.
        cd "$PROJECT_ROOT/$DOMAINS_DIR"
        exec python3 "$SCRIPT_DIR/xlator.py" "$@"
        ;;
esac
