#!/bin/bash
set -e

# Resolve SCRIPT_DIR to the directory containing this script, following symlinks.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname -- "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname -- "$SOURCE")" >/dev/null 2>&1 && pwd)"

# Resolve the project root (the directory that contains xlator.conf).
if [ -f "xlator.conf" ]; then
    PROJECT_ROOT="$(pwd)"
elif git rev-parse --show-toplevel >/dev/null 2>&1; then
    PROJECT_ROOT="$(git rev-parse --show-toplevel)"
else
    echo "Error: Cannot find project root. Create xlator.conf in the project root." >&2
    exit 1
fi

if [ ! -f "$PROJECT_ROOT/xlator.conf" ]; then
    echo "Error: $PROJECT_ROOT/xlator.conf not found. Create xlator.conf in the project root." >&2
    exit 2
fi

# Load xlator.conf and auto-export all variables (including relative path DOMAINS_DIR and CLAUDE_PLUGIN_ROOT).
set -o allexport
source "$PROJECT_ROOT/xlator.conf"
source "$PROJECT_ROOT/.xlator.local.env"

if [ -z "$DOMAINS_DIR" ]; then
    echo "Error: DOMAINS_DIR not set in xlator.conf." >&2
    exit 3
fi

# Not necessarily an absolute path
# This avoids scripts having to know about PROJECT_ROOT when DOMAINS_FULLPATH is sufficient
export DOMAINS_FULLPATH="$PROJECT_ROOT/$DOMAINS_DIR"

activate_opam() {
    if [ -d "$HOME/.opam" ]; then
        eval "$(opam env)"
    else
        echo "Warning: opam environment not found. Run 'xlator_setup.sh' to initialize opam and set up OCaml and Catala." >&2
    fi
}

activate_venv() {
    if [ -f "$XLATOR_UV_BASEDIR/.venv/bin/activate" ]; then
        . "$XLATOR_UV_BASEDIR/.venv/bin/activate"
    else
        echo "Warning: No virtual environment found at $XLATOR_UV_BASEDIR/.venv. Run 'xlator_setup.sh' to create it." >&2
    fi
}

# Activate Python venv and Catala/clerk (opam) environments.
# Required because Claude Code does not source shell configuration files.
activate_venv
activate_opam

# If no command is given, open an interactive shell with the Xlator environment.
if [ $# -eq 0 ]; then
    if command -v python >/dev/null && command -v clerk >/dev/null && command -v catala >/dev/null 2>&1; then
        echo "$(which python): $(python --version)"
        echo "$(which opam) version: $(opam --version)"
        echo "$(which clerk) version: $(clerk --version)"
        echo "$(which catala) version: $(catala --version)"
        exit 0
    fi

    echo "Starting a new shell with Xlator environment activated (python, catala, and clerk commands available)"
    case "$SHELL" in
        */zsh)
            exec zsh --login -i -c 'source ~/.zshrc 2>/dev/null; eval "$(opam env); cd "$PROJECT_ROOT/$DOMAINS_DIR" && source ./.venv/bin/activate""; exec zsh'
            ;;
        *)
            exec bash --rcfile <(
                cat ~/.bashrc 2>/dev/null || true
                echo 'eval "$(opam env)"'
                echo "cd \"$PROJECT_ROOT/$DOMAINS_DIR\" && source ./.venv/bin/activate"
            )
            ;;
    esac
fi

case "$1" in
    # Intended for internal use by Xlator developers or Claude hooks; not commands for user's direct use
    generate-schema)
        exec python3 "$SCRIPT_DIR/../tools/civil_schema.py"
        ;;
    observe_hook)
        event_type="$2"
        case "${OBSERVE_HOOK_DISABLED:-}" in
            1|true|yes)
                ;;
            *)
                exec python3 "$SCRIPT_DIR/../tools/observe_hook.py" $event_type
                ;;
        esac
        ;;
    diff-report)
        domain="$2"
        exec python3 "$SCRIPT_DIR/../tools/diff_report.py" "$domain"
        ;;
    tidy-log)
        domain="$2"
        exec python3 "$SCRIPT_DIR/../tools/tidy_obs_log.py" "$domain"
        ;;
    # For any other command, run xlator.py with the given arguments.
    # This allows users (and Claude) to run any xlator.py command directly via this script,
    # without needing to know where xlator.py is or worry about environment variables,
    # since this script sets up the environment and then delegates to xlator.py.
    *)
        # Change into DOMAINS_DIR so relative paths produced by xlator.py stay within it.
        cd "$DOMAINS_FULLPATH"
        exec python3 "$SCRIPT_DIR/../tools/xlator.py" "$@"
        ;;
esac
